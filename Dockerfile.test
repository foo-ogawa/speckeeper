ARG NODE_VERSION=22
FROM node:${NODE_VERSION}-alpine
WORKDIR /app
COPY package.json package-lock.json .npmrc ./
# agent-contracts-analyzer is a private git devDependency; types are vendored in
# src/external/analyzer-types.ts so CI can npm ci without git credentials.
RUN npm pkg delete devDependencies.agent-contracts-analyzer \
 && npm ci --legacy-peer-deps
COPY . .
RUN npm run build
CMD ["npm", "run", "test"]
