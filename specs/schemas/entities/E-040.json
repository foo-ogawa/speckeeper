{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "entities/APIRef.json",
  "title": "APIRef",
  "description": "Reference to external API (OpenAPI)",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ID"
    },
    "specPath": {
      "type": "string",
      "description": "OpenAPI file path"
    },
    "operationId": {
      "type": "string",
      "description": "Operation ID"
    },
    "componentId": {
      "type": "string",
      "description": "Related component ID"
    }
  },
  "required": [
    "id",
    "specPath",
    "operationId",
    "componentId"
  ],
  "additionalProperties": false
}