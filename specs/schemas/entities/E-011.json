{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "entities/Boundary.json",
  "title": "Boundary",
  "description": "Architecture boundary (system boundary, subsystem boundary, etc.)",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ID"
    },
    "name": {
      "type": "string",
      "description": "Boundary name"
    },
    "description": {
      "type": "string",
      "description": "Description"
    },
    "type": {
      "type": "string",
      "enum": [
        "enterprise",
        "system",
        "container"
      ],
      "description": "Boundary type"
    }
  },
  "required": [
    "id",
    "name",
    "description",
    "type"
  ],
  "additionalProperties": false
}