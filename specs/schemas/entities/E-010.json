{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "entities/Component.json",
  "title": "Component",
  "description": "Architecture component (system, container, component, person)",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ID (e.g., COMP-001)"
    },
    "name": {
      "type": "string",
      "description": "Component name"
    },
    "description": {
      "type": "string",
      "description": "Description"
    },
    "type": {
      "type": "string",
      "enum": [
        "person",
        "system",
        "container",
        "component"
      ],
      "description": "Component type"
    },
    "external": {
      "type": "boolean",
      "description": "Is external component"
    },
    "layerId": {
      "type": "string",
      "description": "Owning layer ID"
    },
    "boundaryId": {
      "type": "string",
      "description": "Owning boundary ID"
    }
  },
  "required": [
    "id",
    "name",
    "description",
    "type",
    "external",
    "layerId",
    "boundaryId"
  ],
  "additionalProperties": false
}