{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "entities/Entity.json",
  "title": "Entity",
  "description": "Concept model entity",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ID (e.g., ENT-001)"
    },
    "name": {
      "type": "string",
      "description": "Entity name"
    },
    "description": {
      "type": "string",
      "description": "Description"
    },
    "isAggregate": {
      "type": "boolean",
      "description": "Is aggregate root"
    },
    "boundaryId": {
      "type": "string",
      "description": "Owning boundary ID"
    }
  },
  "required": [
    "id",
    "name",
    "description",
    "isAggregate",
    "boundaryId"
  ],
  "additionalProperties": false
}