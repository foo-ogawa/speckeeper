{
  "name": "speckeeper",
  "version": "0.15.0",
  "description": "TypeScript-first specification validation framework with external SSOT integration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dsl": {
      "import": "./dist/dsl/index.js",
      "types": "./dist/dsl/index.d.ts"
    }
  },
  "bin": {
    "speckeeper": "dist/speckeeper.bundle.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/speckeeper.bundle.mjs",
    "dist/speckeeper.bundle.mjs.map",
    "dist",
    "docs",
    "cli-contract.yaml"
  ],
  "scripts": {
    "build": "tsup",
    "bundle": "node esbuild.bundle.mjs",
    "bundle:min": "node esbuild.bundle.mjs --minify",
    "build:docs": "npm run build && embedoc build",
    "dev": "tsup --watch",
    "lint": "eslint",
    "lint:design": "eslint design/",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run bundle:min && npm run test:run",
    "docs": "embedoc build",
    "docs:watch": "embedoc watch",
    "dsl:generate": "npx agent-runtime generate --config dsl/agent-runtime.config.yaml",
    "contract:validate": "npx cli-contracts validate",
    "contract:generate": "npx cli-contracts generate",
    "ci": "npm run ci:validate && npm run ci:generate && npm run ci:verify",
    "ci:validate": "npm run typecheck && npm run lint && npm run lint:design && npm run build && npm run bundle && npx speckeeper lint && npm run test:run",
    "ci:generate": "embedoc build",
    "ci:verify": "npx speckeeper check external-ssot && npx speckeeper check test && npx speckeeper check test --coverage",
    "test:ci": "vitest run"
  },
  "keywords": [
    "requirements",
    "design",
    "documentation",
    "markdown",
    "mermaid",
    "typescript",
    "dsl",
    "architecture",
    "c4-model"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "embedoc": "^0.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.11.0",
    "@types/node-sql-parser": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.1.7",
    "agent-contracts": "^0.30.1",
    "agent-contracts-runtime": "^0.30.0",
    "chalk": "^5.3.0",
    "cli-contracts": "^0.32.0",
    "commander": "^12.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "glob": "^10.3.10",
    "node-sql-parser": "^5.4.0",
    "tsup": "^8.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.7",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  }
}
